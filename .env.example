# QR Code Encoder/Decoder - Environment Variables Example
# Скопируйте этот файл в .env и настройте параметры

# Папка для выходных файлов QR-кодов
QR_OUTPUT_DIR=qr_output

# Версия QR-кода по умолчанию (1-40, пустое = автоподбор)
QR_VERSION=

# Коррекция ошибок по умолчанию (L/M/Q/H)
QR_ERROR_CORRECTION=M

# Стиль QR-кода по умолчанию (square/circle)
QR_STYLE=square

# Позиция метаданных (top/bottom)
QR_METADATA_POSITION=top

# Метод сжатия по умолчанию (auto/zip/gzip/bz2/lzma/none)
QR_COMPRESS_METHOD=auto

# Режим кодирования по умолчанию (auto/text/binary)
QR_ENCODE_MODE=auto
